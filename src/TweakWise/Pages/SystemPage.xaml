<Page x:Class="TweakWise.Pages.SystemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Система"
      Background="{DynamicResource ContentBackground}">
    <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="Система"
                           FontSize="28"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Здесь собраны только самые полезные данные о железе: температуры, состояние системы, накопители и доступные расширенные функции."
                           Margin="0,8,0,0"
                           Opacity="0.8"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <UniformGrid Columns="2" Margin="0,0,0,18">
                <Border Margin="0,0,10,10"
                        Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Процессор"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="CpuNameTextBlock"
                                   Margin="0,10,0,0"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="CpuTemperatureTextBlock" Margin="0,10,0,0"/>
                        <TextBlock x:Name="CpuLoadTextBlock" Margin="0,4,0,0"/>
                        <TextBlock x:Name="CpuClockTextBlock" Margin="0,4,0,0"/>
                        <TextBlock x:Name="CpuPowerTextBlock" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Margin="10,0,0,10"
                        Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Видеокарта"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="GpuNameTextBlock"
                                   Margin="0,10,0,0"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="GpuTemperatureTextBlock" Margin="0,10,0,0"/>
                        <TextBlock x:Name="GpuLoadTextBlock" Margin="0,4,0,0"/>
                        <TextBlock x:Name="GpuClockTextBlock" Margin="0,4,0,0"/>
                        <TextBlock x:Name="GpuMemoryTextBlock" Margin="0,4,0,0"/>
                        <TextBlock x:Name="GpuFanTextBlock" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,10,10,0"
                        Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Память и диски"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="MemorySummaryTextBlock"
                                   Margin="0,10,0,0"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="StorageSummaryTextBlock" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TopStorageTemperatureTextBlock" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="UptimeTextBlock" Margin="0,4,0,0"/>
                        <TextBlock x:Name="LastRefreshTextBlock" Margin="0,4,0,0" Opacity="0.78"/>
                    </StackPanel>
                </Border>

                <Border Margin="10,10,0,0"
                        Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Охлаждение и возможности"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="FanSummaryTextBlock" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="FanControlStatusTextBlock" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="GpuOverclockStatusTextBlock" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Температуры"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Показываются все датчики температуры, которые реально удалось прочитать с этого ПК."
                                   Margin="0,6,0,12"
                                   Opacity="0.75"
                                   TextWrapping="Wrap"/>
                        <ItemsControl x:Name="TemperatureSensorItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" Margin="0,0,12,0" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="О системе"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <ItemsControl x:Name="SystemDetailsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Накопители"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <ItemsControl x:Name="StorageItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ContentBackground}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Value}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Дополнительные датчики"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="Здесь выводятся дополнительные показатели CPU, GPU и системы охлаждения. Если чего-то нет, значит ваш ПК просто не отдаёт этот датчик."
                                   Margin="0,0,0,12"
                                   Opacity="0.75"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="CPU" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="CpuSensorItemsControl" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="GPU" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="GpuSensorItemsControl" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Охлаждение" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="CoolingSensorItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Expander Header="Расширенные настройки GPU и охлаждения"
                      IsExpanded="False"
                      Margin="0,0,0,18">
                <Border Padding="16"
                        Background="{DynamicResource MenuBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="0,0,10,10">
                    <StackPanel>
                        <TextBlock x:Name="GpuTuningStatusTextBlock"
                                   Margin="0,0,0,14"
                                   TextWrapping="Wrap"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сдвиг частоты ядра"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="GpuCoreOffsetTextBox"
                                     Grid.Column="1"
                                     Margin="10,0,10,0"/>
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Opacity="0.7"
                                       Text="Изменяет частоту ядра относительно штатного значения. Нужна только опытным пользователям."/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сдвиг частоты памяти"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="GpuMemoryOffsetTextBox"
                                     Grid.Column="1"
                                     Margin="10,0,10,0"/>
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Opacity="0.7"
                                       Text="Изменяет частоту видеопамяти. Если ваш ПК не поддерживает запись, поле останется только справочным."/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Цель по вентилятору GPU"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="GpuFanTargetTextBox"
                                     Grid.Column="1"
                                     Margin="10,0,10,0"/>
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Opacity="0.7"
                                       Text="Желаемая скорость вентилятора в процентах. Работает только на совместимых видеокартах и драйверах."/>
                        </Grid>

                        <WrapPanel Margin="-5,0,0,0">
                            <Button x:Name="ApplyGpuTuningButton"
                                    Content="Применить"
                                    Style="{StaticResource DialogPrimaryButtonStyle}"
                                    Margin="5"
                                    Padding="14,8"
                                    Click="ApplyGpuTuning_Click"/>
                            <Button x:Name="ResetGpuTuningButton"
                                    Content="Очистить поля"
                                    Style="{StaticResource DialogActionButtonStyle}"
                                    Margin="5"
                                    Padding="14,8"
                                    Click="ResetGpuTuning_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Expander>

            <Border Padding="16"
                    Background="{DynamicResource MenuBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Инструменты"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <WrapPanel Margin="-5">
                        <Button Content="Обновить данные"
                                Style="{StaticResource DialogPrimaryButtonStyle}"
                                Margin="5"
                                Padding="14,8"
                                Click="RefreshSystemInfo_Click"/>
                        <Button Content="Диспетчер задач"
                                Style="{StaticResource DialogActionButtonStyle}"
                                Margin="5"
                                Padding="14,8"
                                Click="OpenTaskManager_Click"/>
                        <Button Content="Монитор ресурсов"
                                Style="{StaticResource DialogActionButtonStyle}"
                                Margin="5"
                                Padding="14,8"
                                Click="OpenResourceMonitor_Click"/>
                        <Button Content="Диспетчер устройств"
                                Style="{StaticResource DialogActionButtonStyle}"
                                Margin="5"
                                Padding="14,8"
                                Click="OpenDeviceManager_Click"/>
                        <Button Content="Сведения о системе"
                                Style="{StaticResource DialogActionButtonStyle}"
                                Margin="5"
                                Padding="14,8"
                                Click="OpenSystemInformation_Click"/>
                        <Button Content="Параметры системы"
                                Style="{StaticResource DialogActionButtonStyle}"
                                Margin="5"
                                Padding="14,8"
                                Click="OpenSystemSettings_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
