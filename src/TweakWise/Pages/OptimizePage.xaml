<Page x:Class="TweakWise.Pages.OptimizePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оптимизация" Background="{DynamicResource ContentBackground}">
    <ScrollViewer Padding="20">
        <StackPanel>
            <TextBlock Text="Дополнительная оптимизация системы" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>
            <GroupBox Header="Скорость работы" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <CheckBox Content="Отключить визуальные эффекты (лучшая производительность)" Margin="0,5"/>
                    <CheckBox Content="Отключить анимацию окон" Margin="0,5"/>
                    <CheckBox Content="Отключить прозрачность (эффект Fluent)" Margin="0,5"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Управление питанием" Padding="10">
                <StackPanel>
                    <RadioButton Content="Схема питания: Максимальная производительность" GroupName="Power" Margin="0,5"/>
                    <RadioButton Content="Схема питания: Сбалансированная" GroupName="Power" Margin="0,5" IsChecked="True"/>
                    <RadioButton Content="Схема питания: Экономия энергии" GroupName="Power" Margin="0,5"/>
                </StackPanel>
            </GroupBox>
            <Button Content="Применить выбранные настройки" Width="220" Margin="0,20,0,0" HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</Page>