<Page x:Class="TweakWise.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:TweakWise.Controls"
      Title="Главная"
      Background="{DynamicResource ContentBackground}">
    <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CatalogSectionBorderStyle}"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Главная"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="TweakWise собирает понятные настройки Windows по смысловым разделам: обычные сценарии остаются простыми, а технические детали раскрываются только там, где они действительно нужны."
                               Margin="0,10,0,0"
                               Opacity="0.88"
                               TextWrapping="Wrap"/>

                    <ItemsControl x:Name="SummaryItemsControl" Margin="0,18,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CatalogSubtlePanelStyle}"
                                        Width="180"
                                        Margin="0,0,12,12"
                                        Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Value}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="{Binding Label}"
                                                   Margin="0,4,0,0"
                                                   Opacity="0.86"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Text="Шаблоны"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,8,0,6"/>
            <TextBlock Text="Быстрые сценарии для старта. Они опираются на тот же каталог настроек, поэтому позже их можно будет открыть и донастроить поштучно."
                       Margin="0,0,0,14"
                       Opacity="0.82"
                       TextWrapping="Wrap"/>

            <ItemsControl x:Name="TemplatesItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:LocalTemplateCardControl TemplateCard="{Binding}"
                                                           Width="300"
                                                           Margin="0,0,14,14"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Рекомендованные настройки"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,18,0,6"/>
            <TextBlock Text="Это не отдельный режим для экспертов: смысл, риск, источник и обратимость сразу видны на карточке, а технические детали остаются только в раскрываемой области."
                       Margin="0,0,0,14"
                       Opacity="0.82"
                       TextWrapping="Wrap"/>

            <ItemsControl x:Name="FeaturedTweaksItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:SettingCardControl Setting="{Binding}"
                                                     Width="360"
                                                     Margin="0,0,14,14"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Разделы приложения"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,18,0,6"/>
            <TextBlock Text="Целевая структура уже заложена в каталоге настроек. Следующие этапы будут по очереди переносить под неё существующие страницы, не ломая общий каркас приложения."
                       Margin="0,0,0,14"
                       Opacity="0.82"
                       TextWrapping="Wrap"/>

            <ItemsControl x:Name="CategoriesItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CatalogCardBorderStyle}"
                                Width="380"
                                Margin="0,0,14,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="18"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}"
                                           Margin="0,10,0,0"
                                           Opacity="0.84"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Subcategories}"
                                           Margin="0,12,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Stats}"
                                           Margin="0,10,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SourceMix}"
                                           Margin="0,6,0,0"
                                           Opacity="0.78"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource CatalogSectionBorderStyle}"
                    Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock Text="Как это будет работать дальше"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Откат не выносится в отдельный top-level раздел: каждая настройка уже получает rollback-метаданные и позже будет применять откат локально, рядом с самим изменением."
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Raw registry names не становятся основным UI-текстом: в каталоге уже используются human-first названия, а технические детали остаются в details-панели."
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
