<Page x:Class="TweakWise.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная" Background="{DynamicResource ContentBackground}">
    <ScrollViewer Padding="20">
        <StackPanel>
            <TextBlock Text="Автоматическая оптимизация" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>
            <Border Background="{DynamicResource MenuBackground}" Padding="15" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel>
                    <TextBlock Text="Применить рекомендуемые настройки одним кликом" FontSize="16" Margin="0,0,0,15"/>
                    <Expander Header="Состав оптимизации (нажмите, чтобы изменить)" IsExpanded="True" Background="{DynamicResource MenuBackground}">
                        <StackPanel Margin="20,10,0,10">
                            <CheckBox Content="Отключить телеметрию и сбор данных" IsChecked="True" Margin="0,5"/>
                            <CheckBox Content="Отключить рекламу в меню Пуск" IsChecked="True" Margin="0,5"/>
                            <CheckBox Content="Отключить индексацию поиска (для SSD)" IsChecked="False" Margin="0,5"/>
                            <CheckBox Content="Отключить анимации и спецэффекты" IsChecked="False" Margin="0,5"/>
                            <CheckBox Content="Отключить автоматические обновления драйверов" IsChecked="True" Margin="0,5"/>
                            <TextBlock Text="* Снимите галочки с тех пунктов, которые не хотите применять" Foreground="Gray" FontSize="12" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Expander>
                    <Button Content="🚀 Применить выбранную оптимизацию" HorizontalAlignment="Left" Padding="20,10" Margin="0,20,0,0" Click="ApplyOptimization_Click"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Добро пожаловать в TweakWise!" FontSize="20" Margin="0,30,0,10"/>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,20">
                Используйте меню слева для перехода к разделам тонкой настройки Windows.
                Здесь вы сможете управлять скрытыми параметрами реестра, отключать нежелательные функции,
                настраивать внешний вид и поведение системы, а также следить за состоянием железа.
           
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</Page>