<Page x:Class="TweakWise.Pages.ExplorerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:TweakWise.Controls"
      Title="Интерфейс Windows"
      Background="{DynamicResource ContentBackground}">
    <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CatalogSectionBorderStyle}"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Интерфейс Windows"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Здесь собраны повседневные настройки, которые меняют внешний вид и поведение Windows без перегруза техническими терминами. Обычные действия остаются простыми, а детали раскрываются только внутри карточек."
                               Margin="0,10,0,0"
                               Opacity="0.86"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Первый этап этой страницы уже объединяет Проводник, меню Пуск и панель задач на одном смысловом уровне."
                               Margin="0,8,0,0"
                               Opacity="0.8"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Локальные шаблоны"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,8,0,6"/>
            <TextBlock Text="Шаблоны на этой странице собирают несколько связанных изменений в один понятный сценарий, но остаются частью раздела, а не отдельным top-level режимом."
                       Margin="0,0,0,14"
                       Opacity="0.82"
                       TextWrapping="Wrap"/>

            <ItemsControl x:Name="TemplateItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:LocalTemplateCardControl TemplateCard="{Binding}"
                                                           Width="300"
                                                           Margin="0,0,14,14"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="SectionsItemsControl"
                          Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CatalogSectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="22"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}"
                                           Margin="0,8,0,0"
                                           Opacity="0.84"
                                           TextWrapping="Wrap"/>

                                <ItemsControl ItemsSource="{Binding Settings}"
                                              Margin="0,14,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:SettingCardControl Setting="{Binding}"
                                                                         Width="360"
                                                                         Margin="0,0,14,14"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
