<UserControl x:Class="TweakWise.Controls.GlobalSearchBlockControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TweakWise.Controls"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="SearchResultButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource MenuItemSelectedBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchResultTypeBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>

        <Style x:Key="SearchPlaceholderTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.56"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Text, ElementName=GlobalSearchTextBox}" Value=""/>
                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=GlobalSearchTextBox}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Text, ElementName=GlobalSearchTextBox}" Value="{x:Null}"/>
                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=GlobalSearchTextBox}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="ContainerBorder"
                Style="{StaticResource CatalogSectionBorderStyle}"
                Padding="20">
            <StackPanel>
                <TextBlock x:Name="HeaderTextBlock"
                           Text="Глобальный поиск"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="DescriptionTextBlock"
                           Text="Ищет разделы, секции, настройки, шаблоны и быстрые действия по всему приложению."
                           Margin="0,6,0,0"
                           Opacity="0.82"
                           TextWrapping="Wrap"/>

                <Border x:Name="SearchInputBorder"
                        Style="{StaticResource CatalogSubtlePanelStyle}"
                        Margin="0,14,0,0"
                        Padding="12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="⌕"
                                   FontSize="16"
                                   Opacity="0.72"
                                   VerticalAlignment="Center"/>

                        <TextBox x:Name="GlobalSearchTextBox"
                                 Grid.Column="1"
                                 Margin="10,0,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0,10,0,10"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Искать разделы, настройки, шаблоны и действия"
                                 TextChanged="GlobalSearchTextBox_TextChanged"
                                 GotKeyboardFocus="GlobalSearchTextBox_GotKeyboardFocus"
                                 PreviewKeyDown="GlobalSearchTextBox_PreviewKeyDown"/>

                        <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SearchPlaceholderTextStyle}"
                                   Text="Поиск настроек и действий"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="FooterTextBlock"
                           Text="Разделы, секции, настройки, шаблоны и быстрые действия"
                           Margin="0,10,0,0"
                           FontSize="12"
                           Opacity="0.72"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Popup x:Name="GlobalSearchPopup"
               PlacementTarget="{Binding ElementName=SearchInputBorder}"
               Placement="Bottom"
               StaysOpen="False"
               PopupAnimation="Fade"
               AllowsTransparency="True"
               VerticalOffset="6"
               Closed="GlobalSearchPopup_Closed">
            <Border Width="{Binding ActualWidth, ElementName=SearchInputBorder}"
                    MinWidth="360"
                    Background="{DynamicResource MenuBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="GlobalSearchPopupCaption"
                               Text="Быстрый переход и действия"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.74"/>

                    <Grid Grid.Row="1"
                          Margin="0,8,0,0">
                        <ScrollViewer x:Name="GlobalSearchScrollViewer"
                                      MaxHeight="360"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="GlobalSearchResultsItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SearchResultButtonStyle}"
                                                Click="GlobalSearchResultButton_Click"
                                                Tag="{Binding}">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <Border Style="{StaticResource SearchResultTypeBadgeStyle}"
                                                            DockPanel.Dock="Right">
                                                        <TextBlock Text="{Binding ResultTypeText}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>

                                                    <TextBlock Text="{Binding Title}"
                                                               Margin="0,0,10,0"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                </DockPanel>

                                                <TextBlock Text="{Binding PathText}"
                                                           Margin="0,6,0,0"
                                                           Opacity="0.78"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>

                                                <WrapPanel Margin="0,8,0,0">
                                                    <controls:CatalogBadgeControl Text="{Binding SourceBadgeText}"
                                                                                 Tone="{Binding SourceTone}"
                                                                                 Visibility="{Binding HasSourceBadge, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <controls:CatalogBadgeControl Text="{Binding RiskBadgeText}"
                                                                                 Tone="{Binding RiskTone}"
                                                                                 Visibility="{Binding HasRiskBadge, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="GlobalSearchEmptyText"
                                   Text="Ничего не найдено"
                                   FontSize="12"
                                   Opacity="0.78"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
