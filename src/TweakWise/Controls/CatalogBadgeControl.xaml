<UserControl x:Class="TweakWise.Controls.CatalogBadgeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border x:Name="BadgeBorder"
            Style="{StaticResource CatalogBadgeBorderStyle}">
        <TextBlock x:Name="BadgeTextBlock"
                   Style="{StaticResource CatalogBadgeTextStyle}"
                   Text="{Binding Text, ElementName=Root}"/>
    </Border>
</UserControl>
