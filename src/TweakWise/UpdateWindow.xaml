<Window x:Class="TweakWise.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Доступно обновление"
        Width="640" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource MenuBackground}"
                    Padding="10,0"
                    Height="40"
                    CornerRadius="5,5,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Доступно обновление"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource CloseButtonStyle}"
                            Content="&#xE711;"
                            Click="CloseButton_Click"
                            ToolTip="Закрыть"
                            Width="40"
                            Height="32"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,18,20,12">
                <TextBlock x:Name="VersionTextBlock"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="CurrentVersionTextBlock"
                           Margin="0,6,0,0"
                           Opacity="0.85"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Margin="20,0,20,16"
                    Padding="14"
                    CornerRadius="4"
                    Background="{DynamicResource MenuBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ReleaseNotesTextBlock"
                               TextWrapping="Wrap"
                               FontFamily="Consolas"
                               FontSize="13"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="20,0,20,20">
                <Button Content="Позже"
                        Style="{StaticResource DialogActionButtonStyle}"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="LaterButton_Click"/>
                <Button Content="Открыть"
                        Style="{StaticResource DialogPrimaryButtonStyle}"
                        Width="140"
                        Click="DownloadButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
