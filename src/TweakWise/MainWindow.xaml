<Window x:Class="TweakWise.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TweakWise"
        Title="TweakWise - Настройка Windows" 
        Width="1000" Height="600"
        MinWidth="800" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <ControlTemplate x:Key="SettingsButtonTemplate" TargetType="ToggleButton">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <ContentPresenter x:Name="ContentPresenter"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  RenderTransformOrigin="0.5,0.5">
                    <ContentPresenter.RenderTransform>
                        <RotateTransform x:Name="RotateTransform" Angle="0"/>
                    </ContentPresenter.RenderTransform>
                </ContentPresenter>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="RotateTransform"
                                                 Storyboard.TargetProperty="Angle"
                                                 To="360" Duration="0:0:0.5"
                                                 FillBehavior="HoldEnd"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="RotateTransform"
                                                 Storyboard.TargetProperty="Angle"
                                                 To="0" Duration="0:0:0.5"
                                                 FillBehavior="HoldEnd"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="NotificationsButtonTemplate" TargetType="ToggleButton">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <ContentPresenter x:Name="ContentPresenter"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  RenderTransformOrigin="0.5,0.5">
                    <ContentPresenter.RenderTransform>
                        <RotateTransform x:Name="RotateTransform" Angle="0"/>
                    </ContentPresenter.RenderTransform>
                </ContentPresenter>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="RotateTransform"
                                                 Storyboard.TargetProperty="Angle"
                                                 To="180" Duration="0:0:0.15"
                                                 FillBehavior="HoldEnd"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="RotateTransform"
                                                 Storyboard.TargetProperty="Angle"
                                                 To="0" Duration="0:0:0.15"
                                                 FillBehavior="HoldEnd"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <DataTemplate x:Key="NotificationTemplate">
            <Border Background="{DynamicResource MenuBackground}" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="4" 
                    Margin="0,0,0,5" 
                    Padding="10" 
                    Cursor="Hand"
                    Tag="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔔" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding ClickCommand}" CommandParameter="{Binding}"/>
                </Border.InputBindings>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBackground}" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1"
            CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="{DynamicResource MenuBackground}" 
                    Padding="10,0" 
                    Height="40"
                    CornerRadius="5,5,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="TweakWise" 
                                   FontSize="16" FontWeight="SemiBold" 
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource WindowForeground}"/>
                        <Border Margin="8,0,0,0"
                                Padding="8,2"
                                Background="{DynamicResource MenuItemHoverBackground}"
                                CornerRadius="10"
                                VerticalAlignment="Center">
                            <TextBlock Text="{x:Static local:AppInfo.DisplayVersion}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.9"
                                       Foreground="{DynamicResource WindowForeground}"/>
                        </Border>
                    </StackPanel>

                    <ToggleButton x:Name="NotificationsButton" Grid.Column="2"
                                  FontFamily="Segoe MDL2 Assets" Content="&#xE70E;" 
                                  FontSize="18" Width="32" Height="32" 
                                  Background="Transparent" 
                                  BorderBrush="{x:Null}" 
                                  BorderThickness="0"
                                  Foreground="{DynamicResource WindowForeground}"
                                  Cursor="Hand" 
                                  ToolTip="Уведомления"
                                  Template="{StaticResource NotificationsButtonTemplate}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>

                    <Border x:Name="NotificationBadge" Grid.Column="2"
                            Background="{DynamicResource NotificationBadgeColor}"
                            CornerRadius="8" Width="16" Height="16"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="20,2,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="BadgeCount" Text="0" Foreground="White" 
                                   FontSize="10" HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>

                    <ToggleButton x:Name="SettingsButton" Grid.Column="3"
                                  FontFamily="Segoe MDL2 Assets" Content="&#xE713;" 
                                  FontSize="18" Width="32" Height="32" 
                                  Background="Transparent" 
                                  BorderBrush="{x:Null}" 
                                  BorderThickness="0"
                                  Foreground="{DynamicResource WindowForeground}"
                                  Cursor="Hand" 
                                  ToolTip="Настройки программы"
                                  Template="{StaticResource SettingsButtonTemplate}"
                                  VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeButton" 
                                Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE949;" 
                                Click="MinimizeButton_Click"
                                ToolTip="Свернуть"/>
                        <Button x:Name="MaximizeButton" 
                                Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE739;" 
                                Click="MaximizeButton_Click"
                                ToolTip="Развернуть"/>
                        <Button x:Name="CloseButton" 
                                Style="{StaticResource CloseButtonStyle}"
                                Content="&#xE711;" 
                                Click="CloseButton_Click"
                                ToolTip="Закрыть"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource MenuBackground}" 
                        BorderThickness="0,0,1,0" 
                        BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel Margin="0,10,0,0" Cursor="">
                        <Button x:Name="NavDashboard" Content="🏠 Главная" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Dashboard"/>
                        <Button x:Name="NavExplorer" Content="📁 Проводник" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Explorer"/>
                        <Button x:Name="NavStartMenu" Content="📔 Меню Пуск" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="StartMenu"/>
                        <Button x:Name="NavTaskbar" Content="📌 Панель задач" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Taskbar"/>
                        <Button x:Name="NavOptimize" Content="⚡ Оптимизация" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Optimize"/>
                        <Button x:Name="NavSystem" Content="🖥️ Система" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="System"/>
                    </StackPanel>
                </Border>

                <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="{DynamicResource ContentBackground}"/>
            </Grid>

            <Popup x:Name="SettingsPopup" 
       PlacementTarget="{Binding ElementName=SettingsButton}" 
       Placement="Bottom" 
       StaysOpen="False" 
       PopupAnimation="Fade" 
       AllowsTransparency="True"
       HorizontalOffset="-150" 
       VerticalOffset="5" 
       Closed="SettingsPopup_Closed">
                <Border Background="{DynamicResource MenuBackground}" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="5" 
            Padding="15">
                    <StackPanel MinWidth="200">
                        <TextBlock Text="Настройки" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Text="Тема оформления" Margin="0,5,0,5"/>
                        <RadioButton x:Name="ThemeSystem" Content="Системная" GroupName="Theme" Checked="ThemeRadio_Checked" IsChecked="True" Margin="5,2"/>
                        <RadioButton x:Name="ThemeLight" Content="Светлая" GroupName="Theme" Checked="ThemeRadio_Checked" Margin="5,2"/>
                        <RadioButton x:Name="ThemeDark" Content="Тёмная" GroupName="Theme" Checked="ThemeRadio_Checked" Margin="5,2"/>
                        <Separator Margin="0,10,0,10"/>
                        <CheckBox x:Name="RunOnStartupCheckBox" Content="Запуск вместе с Windows" Margin="0,3" Checked="SettingsCheckBox_Changed" Unchecked="SettingsCheckBox_Changed"/>
                        <CheckBox x:Name="AutoCheckUpdatesCheckBox" Content="Автоматически проверять обновления" Margin="0,3" Checked="SettingsCheckBox_Changed" Unchecked="SettingsCheckBox_Changed"/>
                        <CheckBox x:Name="ShowNotificationsCheckBox" Content="Показывать уведомления" Margin="0,3" Checked="SettingsCheckBox_Changed" Unchecked="SettingsCheckBox_Changed"/>
                        <Separator Margin="0,10,0,10"/>
                        <Button x:Name="CheckUpdatesButton" Content="Проверить наличие обновлений"
                                Style="{StaticResource DialogActionButtonStyle}"
                                Margin="0,0,0,5"
                                Click="CheckUpdatesButton_Click"/>
                        <Button x:Name="ResetButton" Content="Сбросить все настройки"
                                Style="{StaticResource DialogActionButtonStyle}"
                                Margin="0,5,0,0"
                                Click="ResetButton_Click"/>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="NotificationsPopup" 
                   PlacementTarget="{Binding ElementName=NotificationsButton}" 
                   Placement="Bottom" 
                   StaysOpen="False" 
                   PopupAnimation="Fade" 
                   AllowsTransparency="True"
                   HorizontalOffset="-250" 
                   VerticalOffset="5" 
                   Closed="NotificationsPopup_Closed"
                   Opened="NotificationsPopup_Opened">
                <Border Background="{DynamicResource MenuBackground}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="10" 
                        MinWidth="300" MaxWidth="400" MaxHeight="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Уведомления" FontSize="16" FontWeight="SemiBold"/>
                            <Button Content="Очистить все" Margin="10,0,0,0" Padding="5,2" Click="ClearAllNotifications_Click" FontSize="12"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <ScrollViewer x:Name="NotificationsScrollViewer" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="NotificationsList" 
                                              ItemTemplate="{StaticResource NotificationTemplate}"
                                              Background="Transparent">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock x:Name="EmptyNotificationsText"
                                       Text="Нет уведомлений"
                                       FontSize="12"
                                       Opacity="0.8"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
